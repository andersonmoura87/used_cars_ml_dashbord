# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=used_cars
DB_USER=postgres
DB_PASSWORD=postgres

# Configurações do Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Configurações da API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
API_DEBUG=False

# Configurações do Dashboard
DASHBOARD_PORT=8501

# Configurações de Log
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Configurações de Cache
CACHE_TTL=3600  # Tempo de vida do cache em segundos
CACHE_DIR=cache

# Configurações de ETL
BATCH_SIZE=1000
MAX_WORKERS=4
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# Test Database Configuration
TEST_DB_NAME=mobato_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres

# Data paths
RAW_DATA_PATH=data/raw/used_cars.csv
PROCESSED_DATA_PATH=data/processed/

# Security
SECRET_KEY=your_secret_key_min_32_chars
API_KEY=your_api_key_here

# CORS — lista separada por vírgula das origens permitidas
# Em produção: substitua pelos domínios reais (sem wildcard *)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Great Expectations — Data Quality
# Defina como "false" para desabilitar sem remover o pacote
GE_ENABLED=true

# MLflow — Experiment Tracking
# Deixe em branco para desabilitar o tracking (modo local/offline)
# Docker: http://mlflow:5000  |  Local: http://localhost:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=used_cars_price_model
# Nome do modelo no Model Registry (Stage: Staging / Production)
MLFLOW_REGISTERED_MODEL=used_cars_price_model