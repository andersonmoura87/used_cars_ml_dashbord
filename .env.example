# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copie para .env e preencha TODOS os valores antes de usar
# Gerar senhas fortes: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=used_cars
DB_USER=postgres
# M-19 FIX: sem senha exemplo hardcoded — gere com: openssl rand -hex 32
DB_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# H-05 FIX: Redis com autenticação — gere com: openssl rand -hex 32
REDIS_PASSWORD=

# ── pgAdmin (apenas com: docker compose --profile tools up) ──────────────────
PGADMIN_EMAIL=admin@localhost
# C-02 FIX: sem senha padrão — gere com: openssl rand -hex 16
PGADMIN_PASSWORD=

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0   # Em bare-metal atrás de proxy: use 127.0.0.1
API_PORT=8000
API_WORKERS=2
API_RELOAD=false   # true apenas em desenvolvimento local
ENVIRONMENT=development   # production | staging | development

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Log ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=3600
CACHE_DIR=cache

# ── ETL ───────────────────────────────────────────────────────────────────────
BATCH_SIZE=1000
MAX_WORKERS=4
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
RAW_DATA_PATH=data/raw/used_cars.csv
PROCESSED_DATA_PATH=data/processed/

# ── Segurança ─────────────────────────────────────────────────────────────────
# M-19 FIX: sem placeholder previsível — gere com: openssl rand -hex 32
SECRET_KEY=
# Chave de autenticação da API — gere com: openssl rand -hex 32
API_KEY=

# Rate limiting (M-02) — requests por IP por janela de tempo
API_RATE_LIMIT=200/minute

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista separada por vírgula. Em produção: domínios reais sem wildcard *
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Staging ───────────────────────────────────────────────────────────────────
# M-20 FIX: sem valor padrão previsível — gere com: openssl rand -hex 32
STAGING_API_KEY=
DB_PASSWORD_STAGING=
REDIS_PASSWORD_STAGING=

# ── Great Expectations ────────────────────────────────────────────────────────
GE_ENABLED=true

# ── MLflow ────────────────────────────────────────────────────────────────────
# Deixe em branco para desabilitar o tracking
# Docker: http://mlflow:5000  |  Local: http://localhost:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=used_cars_price_model
MLFLOW_REGISTERED_MODEL=used_cars_price_model

# ── Banco de dados de teste ───────────────────────────────────────────────────
TEST_DB_NAME=used_cars_test
TEST_DB_USER=postgres
# Gere com: openssl rand -hex 32
TEST_DB_PASSWORD=
