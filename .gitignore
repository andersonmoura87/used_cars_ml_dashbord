# ── Secrets e configuração local ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
# manter apenas o exemplo
!.env.example

# ── Dados — não versionar CSVs/Parquets brutos ou processados ─────────────────
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json
data/processed/*.csv
data/processed/*.parquet
data/interim/
# manter estrutura de diretórios
!data/**/.gitkeep

# ── Artefatos de modelo ───────────────────────────────────────────────────────
models/*.joblib
mlruns/
gx/uncommitted/
# Código legado arquivado (mantido para referência, não vai pro package)
archive/
models/*.pkl
models/*.pickle
models/*.pt
models/*.pth
models/*.h5
models/*.onnx
# manter metadados e ponteiro latest
!models/*.json
!models/latest.txt
!models/.gitkeep
!models/.gitignore

# ── Outputs gerados ───────────────────────────────────────────────────────────
reports/figures/
reports/*.pdf
reports/*.html
metrics/
logs/
*.log

